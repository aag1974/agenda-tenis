# Configuração do servidor local. Credenciais dos atletas ficam
# em data/profiles.json criptografadas, não aqui.
PORT=4173

# Web Push — gerar par de chaves uma vez:
#   node -e "import('web-push').then(wp => { const k = wp.default.generateVAPIDKeys(); console.log(k); })"
# Public key vai pro frontend; private fica só no servidor.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@tennis-flow.com
